# =============================================================================
# TGBot-Ultra-v1 Job 任务服务环境变量配置
# 此文件将被挂载到容器内作为 Hyperf 的 .env 文件
# =============================================================================

APP_NAME=TGBot-Job
APP_ENV=production
APP_DEBUG=false

# 数据库配置（必须与 .env 文件中的配置一致）
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tgbot
DB_USERNAME=root
DB_PASSWORD=rootpassword
DB_PREFIX=t_

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_AUTH=
REDIS_DB=1

# API-Web 服务地址（必须配置，必须与 .env 文件中的配置一致）
# 生产环境默认使用 5h1-api.hfz.pw，如需自定义可改成自己的域名
API_WEB_URL=https://5h1-api.hfz.pw

# NL-API 能量池系统地址（tgnl-home 生产域名，Job 通过此地址调用 /v1/get_api_user_info、/v1/delegate_meal）
# 如需自定义可改为自己的域名或内网地址
NL_API_BASE_URL=https://tgnl-home.hfz.pw

# Hyperf 配置
HYPERF_SERVER_HOST=0.0.0.0
HYPERF_SERVER_PORT=9503
