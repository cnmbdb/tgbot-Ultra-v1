# =============================================================================
# TGBot-Ultra-v1 Admin 后台环境变量配置
# 此文件将被挂载到容器内作为 Laravel 的 .env 文件
# =============================================================================

APP_NAME=TGBot
APP_ENV=production
APP_KEY=base64:your-app-key-here
APP_DEBUG=false
APP_URL=http://your-server-ip:8080

# HTTPS 配置（使用 HTTPS + SSL 时设置为 true）
IS_HTTPS=false

LOG_CHANNEL=stack
LOG_LEVEL=debug

# 数据库配置（必须与 .env 文件中的配置一致）
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tgbot
DB_USERNAME=root
DB_PASSWORD=rootpassword

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# API-Web 服务地址（必须配置，必须与 .env 文件中的配置一致）
# 生产环境默认使用 5h1-api.hfz.pw，如需自定义可改成自己的域名
API_WEB_URL=https://5h1-api.hfz.pw

# NL-API 能量池系统地址（tgnl-home 生产域名，机器人通过此地址发起能量下发）
# 如需自定义可改为自己的域名或内网地址
NL_API_BASE_URL=https://tgnl-home.hfz.pw

# Webhook 基础 URL（生产环境设置 Webhook 时使用）
# 绑定域名后填写，例如: https://your-domain.com
# Telegram Webhook 只支持 80/443/88/8443 端口
WEBHOOK_BASE_URL=

# 邮件配置（可选）
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
