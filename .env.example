# Docker Compose 环境变量
# 复制为 .env 并修改

# API-Web 服务地址（必须配置）
API_WEB_URL=http://your-api-server-ip:4444
NL_API_BASE_URL=https://tgnl-home.hfz.pw

# 数据库配置
DB_DATABASE=tgbot
DB_USERNAME=root
DB_PASSWORD=your-secure-password

# 镜像配置（建议生产固定日期标签，避免 latest 漂移）
IMAGE_REPO=hfdoker2333/tgbot-ultra-v1
ADMIN_IMAGE_TAG=admin-20260308
JOB_IMAGE_TAG=job-20260308

# 端口配置（可选）
ADMIN_PORT=8080
JOB_PORT=9503
POSTGRES_PORT=5432
REDIS_PORT=6379
