# API-Web 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# 应用配置
NODE_ENV=production
PORT=4444
HOSTNAME=0.0.0.0

# 数据库配置
DB_HOST=api-web-postgres
DB_PORT=5432
DB_USER=root
DB_PASSWORD=apiwebpassword
DB_NAME=apiweb

# Redis 配置
REDIS_HOST=api-web-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 区块链网络配置
TRON_NETWORK=https://api.trongrid.io
ETH_RPC_URL=https://eth.llamarpc.com

# TON 网络配置（用于开通 Premium）
# TON RPC 节点地址（建议使用你自己的节点或可信服务商）
TON_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
# 如果使用需要 API Key 的服务，填在这里；否则留空
TON_API_KEY=
# Premium 收款地址（TON 地址，机器人后台配置的钱包会往这里付款）
TON_PREMIUM_RECEIVER_ADDRESS=
# 单月 Premium 价格（单位：TON，例如 0.1 代表每月 0.1 TON）
TON_PREMIUM_PRICE_PER_MONTH=0.1

# 安全配置
ALLOWED_ORIGINS=*

# 管理后台登录密码（请务必修改为强密码）
ADMIN_PASSWORD=Apple11.15

# 如果部署在远程服务器，需要配置外部访问地址
# API_WEB_URL=http://your-api-server-ip:4444
